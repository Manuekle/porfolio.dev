---
import Layout from '../../layouts/Layout.astro'
import TopBar from '../../components/TopBar.astro'
import Hero from '../../components/Hero.astro'
import BentoCard from '../../components/BentoCard.astro'
import ProjectDialog from '../../components/ProjectDialog.astro'
import { getTranslations, type Language } from '../../i18n/translations'
import { Image } from 'astro:assets'

const lang: Language = 'es'
const t = getTranslations(lang)

// Tech Stack Icons
import ReactIcon from '../../assets/icons/ReactIcon.astro'
import NextIcon from '../../assets/icons/NextIcon.astro'
import TypescriptIcon from '../../assets/icons/TypescriptIcon.astro'
import TailwindIcon from '../../assets/icons/TailwindIcon.astro'
import NodeIcon from '../../assets/icons/NodeIcon.astro'
import PrismaIcon from '../../assets/icons/PrismaIcon.astro'
import PythonIcon from '../../assets/icons/PythonIcon.astro'
import PostgreIcon from '../../assets/icons/PostgreIcon.astro'
import GitIcon from '../../assets/icons/GitIcon.astro'
import FlutterIcon from '../../assets/icons/FlutterIcon.astro'
import DartIcon from '../../assets/icons/DartIcon.astro'
import MongoIcon from '../../assets/icons/MongoIcon.astro'
import FigmaIcon from '../../assets/icons/FigmaIcon.astro'
import DockerIcon from '../../assets/icons/DockerIcon.astro'
import AstroIcon from '../../assets/icons/AstroIcon.astro'
import JavascriptIcon from '../../assets/icons/JavascriptIcon.astro'
import MySQLIcon from '../../assets/icons/MySQLIcon.astro'
import PostmanIcon from '../../assets/icons/PostmanIcon.astro'
import VercelIcon from '../../assets/icons/VercelIcon.astro'
import OpenAIIcon from '../../assets/icons/OpenAIIcon.astro'
import GeminiIcon from '../../assets/icons/GeminiIcon.astro'
import AnthropicIcon from '../../assets/icons/AnthropicIcon.astro'
import MCPIcon from '../../assets/icons/MCPIcon.astro'
import N8nIcon from '../../assets/icons/N8nIcon.astro'
import MarkdownIcon from '../../assets/icons/MarkdownIcon.astro'
import RedisIcon from '../../assets/icons/RedisIcon.astro'
import MistralIcon from '../../assets/icons/MistralIcon.astro'
import ClaudeIcon from '../../assets/icons/ClaudeIcon.astro'
import KimiIcon from '../../assets/icons/KimiIcon.astro'
import MercadoPagoIcon from '../../assets/icons/MercadoPagoIcon.astro'
import GoogleCloudIcon from '../../assets/icons/GoogleCloudIcon.astro'
import MetaAdsIcon from '../../assets/icons/MetaAdsIcon.astro'
import BunIcon from '../../assets/icons/BunIcon.astro'
import MotionIcon from '../../assets/icons/MotionIcon.astro'
import OllamaIcon from '../../assets/icons/OllamaIcon.astro'

const name = 'Manuel Erazo'
const title = 'Web & AI Developer | React, Next.js & LLM Integrations'

const experience = [
  {
    year: '2025',
    title: 'Desarrollador Web',
    organization: 'Smurfit Kappa Cartón Colombia',
  },
  {
    year: 'Feb 2026',
    title: 'Participante - Mistral Worldwide Hackathon',
    organization: 'Mistral AI x Weights & Biases x NVIDIA',
  },
  {
    year: '2023 - Presente',
    title: 'Desarrollador Web Freelance',
    organization: 'Proyectos Freelance / Académicos',
  },
  {
    year: '2024 - Presente',
    title: 'CEO & Fundador de GymRat+',
    organization: 'GymRat+ - SaaS para Gimnasios',
  },
  {
    year: '2021 - 2026',
    title: 'Estudiante de Ingeniería de Sistemas',
    organization: 'Fundación Universitaria de Popayán',
  },
]

const projects = [
  {
    title: 'GymRat+',
    description:
      lang === 'es'
        ? 'SaaS para la gestión integral de gimnasios. Administra membresías, monitorea asistencia, procesa pagos con MercadoPago y accede a un panel de métricas en tiempo real. Construido pensando en los operadores de gimnasios modernos.'
        : 'A SaaS platform for comprehensive gym management. Handle memberships, monitor attendance, process payments via MercadoPago, and access a real-time metrics dashboard — built for modern gym operators.',
    image: 'https://manudev.vercel.app/gym-banner.png',
    techStack: ['Next.js', 'TypeScript', 'Prisma', 'PostgreSQL', 'MercadoPago'],
    features: [
      lang === 'es' ? 'Gestión de membresías y planes' : 'Membership and plan management',
      lang === 'es' ? 'Control de asistencia y acceso' : 'Attendance and access control',
      lang === 'es' ? 'Pagos integrados con MercadoPago' : 'Integrated payments via MercadoPago',
      lang === 'es' ? 'Panel de métricas en tiempo real' : 'Real-time analytics dashboard',
      lang === 'es' ? 'Notificaciones automáticas' : 'Automated notifications',
    ],
    webLink: 'https://gymratplus.vercel.app/',
    githubLink: 'https://github.com/Manuekle/gymratplus',
  },
  {
    title: 'sira',
    description:
      lang === 'es'
        ? 'Asistente de IA conversacional impulsado por OpenAI y modelos de última generación. Gestiona contexto de conversación, soporta múltiples flujos y permite integrar herramientas externas mediante MCP para automatizar tareas complejas.'
        : 'A conversational AI assistant powered by OpenAI and cutting-edge models. Manages conversation context, supports multiple flows, and connects external tools via MCP to automate complex tasks.',
    image: '/placeholder.jpeg',
    techStack: ['Next.js', 'TypeScript', 'OpenAI', 'MCP', 'Tailwind CSS'],
    features: [
      lang === 'es' ? 'Conversaciones contextuales con memoria' : 'Context-aware conversations with memory',
      lang === 'es' ? 'Integración con OpenAI, Claude y Gemini' : 'Integration with OpenAI, Claude, and Gemini',
      lang === 'es' ? 'Soporte para herramientas via MCP' : 'Tool support via MCP protocol',
      lang === 'es' ? 'Streaming de respuestas en tiempo real' : 'Real-time response streaming',
      lang === 'es' ? 'Interfaz limpia y minimalista' : 'Clean and minimalist interface',
    ],
    githubLink: 'https://github.com/Manuekle/sira',
  },
  {
    title: 'hinomaru',
    description:
      lang === 'es'
        ? 'Sistema integral de gestión para negocios con módulos de inventario, facturación, clientes y reportes. Diseñado para ser rápido de adoptar y fácil de operar, con una interfaz moderna y fluida.'
        : 'A comprehensive business management system with modules for inventory, invoicing, customers, and reporting. Designed for fast onboarding and effortless daily operation with a modern, fluid interface.',
    image: '/placeholder.jpeg',
    techStack: ['Next.js', 'TypeScript', 'Prisma', 'PostgreSQL', 'Tailwind CSS'],
    features: [
      lang === 'es' ? 'Gestión de inventario en tiempo real' : 'Real-time inventory management',
      lang === 'es' ? 'Facturación y pagos integrados' : 'Integrated billing and payments',
      lang === 'es' ? 'CRM básico con historial de clientes' : 'Basic CRM with customer history',
      lang === 'es' ? 'Reportes y analítica de negocio' : 'Business reports and analytics',
      lang === 'es' ? 'Multi-sucursal y roles de usuario' : 'Multi-branch and user roles',
    ],
    githubLink: 'https://github.com/Manuekle/hinomaru',
  },
  {
    title: 'heyMed',
    description:
      lang === 'es'
        ? 'Plataforma digital de salud que conecta pacientes con profesionales médicos para consultas virtuales, gestión de citas y seguimiento de historial clínico. Diseñada con los más altos estándares de privacidad de datos.'
        : 'A digital health platform connecting patients with medical professionals for virtual consultations, appointment management, and clinical history tracking — built with the highest data privacy standards.',
    image: '/placeholder.jpeg',
    techStack: ['Next.js', 'TypeScript', 'Prisma', 'PostgreSQL', 'Tailwind CSS'],
    features: [
      lang === 'es' ? 'Consultas virtuales con videollamada' : 'Virtual consultations with video call',
      lang === 'es' ? 'Gestión de citas y recordatorios' : 'Appointment management and reminders',
      lang === 'es' ? 'Historial clínico seguro del paciente' : 'Secure patient clinical history',
      lang === 'es' ? 'Panel de control para médicos' : 'Doctor control panel',
      lang === 'es' ? 'Notificaciones y alertas automáticas' : 'Automated notifications and alerts',
    ],
    githubLink: 'https://github.com/Manuekle/heyMed',
  },
  {
    title: 'ButterflyAR',
    description:
      lang === 'es'
        ? 'Aplicación educativa de realidad aumentada que da vida a las especies de mariposas en 3D. Combina ARCore y ARKit para una experiencia inmersiva cross-platform que une aprendizaje y tecnología.'
        : 'An educational augmented reality app that brings butterfly species to life in 3D. Combines ARCore and ARKit for an immersive cross-platform experience that merges learning and technology.',
    image: 'https://manudev.vercel.app/butterfly-banner.png',
    techStack: ['Flutter', 'ARCore', 'ARKit', 'Dart'],
    features: [
      lang === 'es' ? 'Visualización AR de especies de mariposas' : 'AR visualization of butterfly species',
      lang === 'es' ? 'Modelos 3D interactivos de alta fidelidad' : 'High-fidelity interactive 3D models',
      lang === 'es' ? 'Contenido educativo con datos y curiosidades' : 'Educational content with facts and trivia',
      lang === 'es' ? 'Identificación de especies por cámara' : 'Species identification via camera',
      lang === 'es' ? 'Soporte multiplataforma (iOS y Android)' : 'Cross-platform support (iOS & Android)',
    ],
    githubLink: 'https://github.com/Manuekle/butterflyar-mobile',
  },
  {
    title: 'QR Attendance',
    description:
      lang === 'es'
        ? 'Sistema de gestión de asistencia con códigos QR para check-ins rápidos en instituciones educativas. Ofrece seguimiento en tiempo real, paneles diferenciados para alumnos y profesores, y reportes exportables.'
        : 'An attendance management system using QR codes for quick check-ins in educational institutions. Offers real-time tracking, separate dashboards for students and teachers, and exportable reports.',
    image: 'https://manudev.vercel.app/edutrack-banner.png',
    techStack: ['Next.js', 'React', 'Node.js', 'MongoDB', 'QR Code API'],
    features: [
      lang === 'es' ? 'Generación de códigos QR por clase' : 'QR code generation per class',
      lang === 'es' ? 'Seguimiento de asistencia en tiempo real' : 'Real-time attendance tracking',
      lang === 'es' ? 'Paneles diferenciados para alumnos y docentes' : 'Separate dashboards for students and teachers',
      lang === 'es' ? 'Reportes y análisis exportables' : 'Exportable reports and analytics',
      lang === 'es' ? 'Notificaciones por correo electrónico' : 'Email notifications',
    ],
    webLink: 'https://edutrack-fup.vercel.app/',
    githubLink: 'https://github.com/Manuekle/edutrack',
  },
]
---

<Layout title="Manuel Erazo - Web Developer" lang={lang}>
  <TopBar nav={{ home: t.nav.home, services: t.nav.services }} lang="es" />

  <Hero name={name} title={title} photoUrl="/placeholder.jpeg" t={t.hero} />

  <!-- Bento Grid -->
  <div class="pb-20 bg-surface">
    <div class="mx-auto max-w-5xl px-6">
      <!-- First Row: 3 columns -->
      <div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-3">
        <!-- My Experience -->
        <BentoCard data-aos="fade-up" data-aos-delay="100">
          <h3
            class="mb-4 w-fit rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold tracking-[-0.02em] text-zinc-500"
          >
            {t.experience.title}
          </h3>
          <div class="space-y-4 overflow-y-auto overflow-x-hidden max-h-[280px] pr-2 scrollbar-hide">
            {
              experience.map((exp) => (
                <div class="flex items-start gap-3">
                  <div class="mt-2 h-2 w-2 flex-shrink-0 rounded-full bg-black" />
                  <div>
                    <div class="text-xs font-semibold">{exp.title}</div>
                    <div class="text-xs text-gray-600">
                      {exp.year} · {exp.organization}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </BentoCard>

        <!-- My Projects -->
        <BentoCard data-aos="fade-up" data-aos-delay="200">
          <h3
            class="mb-4 w-fit rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold tracking-[-0.02em] text-zinc-500"
          >
            {t.projects.title}
          </h3>
          <div class="grid grid-cols-3 gap-1.5">
            {
              projects.map((project) => (
                <button
                  class="open-project-dialog group relative aspect-square overflow-hidden rounded-xl transition-all hover:scale-105"
                  data-project={project.title.toLowerCase().replace(/\s+/g, '-')}
                >
                  <Image
                    src={project.image}
                    alt={project.title}
                    width={100}
                    height={100}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-110"
                  />
                  <div class="absolute inset-0 bg-black/40 opacity-0 transition-opacity duration-200 group-hover:opacity-100" />
                  <span class="absolute inset-x-0 bottom-0 truncate px-1.5 py-1 text-[8px] font-medium text-white opacity-0 transition-opacity duration-200 group-hover:opacity-100">
                    {project.title}
                  </span>
                </button>
              ))
            }
          </div>
          <div class="mt-3 text-xs text-gray-500">{projects.length} {t.projects.clickToView}</div>
        </BentoCard>

        <!-- Tech Stack -->
        <BentoCard data-aos="fade-up" data-aos-delay="300">
          <h3
            class="mb-4 w-fit rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold tracking-[-0.02em] text-zinc-500"
          >
            {t.techStack.title}
          </h3>

          <div class="space-y-4">

              <!-- Frontend -->
              <div>
                <div class="mb-2 text-[10px] font-semibold text-gray-400 uppercase">{t.techStack.frontend}</div>
                <div class="flex flex-wrap gap-2">
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <ReactIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">React</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <NextIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Next.js</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <AstroIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Astro</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <TypescriptIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">TypeScript</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <JavascriptIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">JavaScript</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <TailwindIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Tailwind</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <FlutterIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Flutter</span>
                  </div>
<div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <MotionIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Motion</span>
                  </div>
                </div>
              </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <MarkdownIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Markdown</span>
                  </div>
                </div>
              </div>

              <!-- Backend -->
              <div>
                <div class="mb-2 text-[10px] font-semibold text-gray-400 uppercase">{t.techStack.backend}</div>
                <div class="flex flex-wrap gap-2">
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <NodeIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Node.js</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <PythonIcon class="h-6 w-6" />
                    <span class="text-[10px] text-black">Python</span>
                  </div>
                </div>
              </div>

              <!-- Database -->
              <div>
                <div class="mb-2 text-[10px] font-semibold text-gray-400 uppercase">{t.techStack.database}</div>
                <div class="flex flex-wrap gap-2">
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <PostgreIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">PostgreSQL</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <MySQLIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">MySQL</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <PrismaIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Prisma</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <MongoIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">MongoDB</span>
                  </div>
                </div>
              </div>

              <!-- Tools -->
              <div>
                <div class="mb-2 text-[10px] font-semibold text-gray-400 uppercase">{t.techStack.tools}</div>
                <div class="flex flex-wrap gap-2">
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <GitIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Git</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <FigmaIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Figma</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <DockerIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Docker</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <PostmanIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Postman</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <VercelIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Vercel</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <RedisIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Redis</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <MercadoPagoIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">MercadoPago</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <GoogleCloudIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Google Cloud</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <MetaAdsIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Meta Ads</span>
                  </div>
                </div>
              </div>

              <!-- AI & LLMs -->
              <div>
                <div class="mb-2 text-[10px] font-semibold text-gray-400 uppercase">{t.techStack.ai_llms}</div>
                <div class="flex flex-wrap gap-2">
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <OpenAIIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">OpenAI</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <GeminiIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Gemini</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <AnthropicIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Anthropic</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <MistralIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Mistral</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <ClaudeIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Claude</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <KimiIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Kimi</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <MCPIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">MCP</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <N8nIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">n8n</span>
                  </div>
                  <div class="flex items-center gap-1.5 rounded-full bg-white px-2 py-1">
                    <OllamaIcon class="h-4 w-4" />
                    <span class="text-[10px] text-black">Ollama</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </BentoCard>
      </div>

      <!-- Second Row: 2 columns -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <!-- Location -->
        <BentoCard class="relative overflow-hidden !p-0" data-aos="fade-up" data-aos-delay="400">
          <div class="relative h-full min-h-[300px]">
            <!-- Map Background -->
            <img
              src="/map.png"
              alt="Popayán, Colombia"
              class="absolute inset-0 h-full w-full object-cover"
            />

            <!-- Gradient Overlay -->
            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-b from-black/60 via-black/30 to-black/60"
            >
            </div>

            <!-- Map Button - Top Right -->
            <div class="pointer-events-auto absolute top-4 right-4 z-10">
              <a
                href="https://maps.google.com/?q=Popayán,Colombia"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold text-black transition-colors hover:bg-gray-100"
              >
                Map
              </a>
            </div>

            <!-- Location Text - Centered -->
            <div
              class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center text-center"
            >
              <div class="mb-1 text-4xl font-bold tracking-wider text-white">POPAYÁN</div>
              <div class="text-xs text-white/90">COLOMBIA</div>
            </div>
          </div>
        </BentoCard>

        <!-- How I work -->
        <BentoCard data-aos="fade-up" data-aos-delay="500">
          <h3
            class="mb-4 w-fit rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold tracking-[-0.02em] text-zinc-500"
          >
            {t.howIWork.title}
          </h3>

          <!-- Content Container with Slide Animation -->
          <div class="relative mb-4 h-[120px] overflow-hidden">
            <div id="work-content" class="transition-all duration-300 ease-in-out">
              <div class="work-step active" data-step="1">
                <div class="mb-2 text-lg font-semibold">1 {t.howIWork.step1}</div>
                <p class="text-xs text-gray-600">
                  {t.howIWork.step1Desc}
                </p>
              </div>
              <div class="work-step hidden" data-step="2">
                <div class="mb-2 text-lg font-semibold">2 {t.howIWork.step2}</div>
                <p class="text-xs text-gray-600">
                  {t.howIWork.step2Desc}
                </p>
              </div>
              <div class="work-step hidden" data-step="3">
                <div class="mb-2 text-lg font-semibold">3 {t.howIWork.step3}</div>
                <p class="text-xs text-gray-600">
                  {t.howIWork.step3Desc}
                </p>
